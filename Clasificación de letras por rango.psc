Algoritmo EJERCICIO3
	Definir letra Como Caracter
	Escribir "CLASIFICACION DE LETRAS POR RANGO"
	Escribir Sin Saltar "Digite una letra"
	leer letra
	
	Segun letra Hacer
		"A" o "a":
			Escribir "Excelente"
		"B" o "b":
			Escribir "Bueno"
		"C" o "c":
			Escribir "Regular"
		"D" o "d":
			Escribir "Deficiente"
		"F" o "f":
			Escribir "Reprobado"
		De Otro Modo:
			Escribir "Digite una letra valida entre A,B,C,D,F"
	Fin Segun
FinAlgoritmo
